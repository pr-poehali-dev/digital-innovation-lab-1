{
  "tests": [
    {
      "name": "Proxy trend scan",
      "method": "GET",
      "path": "/?candles=10&timeframe=5",
      "expectedStatus": 200,
      "expectedBody": {"candles": 10},
      "bodyMatcher": "partial"
    },
    {
      "name": "Arbitrage scan",
      "method": "GET",
      "path": "/?mode=arbitrage",
      "expectedStatus": 200,
      "expectedBody": {"source": "CoinGecko"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Live quote BTC",
      "method": "GET",
      "path": "/?mode=quote&symbol=BTCUSDT",
      "expectedStatus": 200,
      "expectedBody": {"symbol": "BTCUSDT"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Live quote EURUSD",
      "method": "GET",
      "path": "/?mode=quote&symbol=EURUSD",
      "expectedStatus": 200,
      "expectedBody": {"symbol": "EURUSD"},
      "bodyMatcher": "partial"
    }
  ]
}